{
  "name": "network_topology",
  "version": "0.1.0",
  "description": "Kibana plugin for network monitoring and topology mapping via SNMP data",
  "license": "Elastic-2.0",
  "private": true,
  "scripts": {
    "build": "yarn plugin-helpers build",
    "dev": "yarn plugin-helpers dev",
    "plugin-helpers": "node ../../scripts/plugin_helpers",
    "kbn": "node ../../scripts/kbn",
    "test:jest": "../../node_modules/.bin/jest --config jest.config.js",
    "lint": "node ../../scripts/eslint.js --ext .js,.jsx,.mjs,.cjs,.ts,.tsx .",
    "lint:fix": "node ../../scripts/eslint.js --ext .js,.jsx,.mjs,.cjs,.ts,.tsx --fix .",
    "check:license_headers": "node scripts/check_license_headers.mjs",
    "fix:license_headers": "node scripts/add_license_headers.mjs",
    "type-check": "../../node_modules/.bin/tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "7.27.6",
    "lz-string": "^1.5.0",
    "d3-force": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "d3-selection": "^3.0.0"
  }
}
